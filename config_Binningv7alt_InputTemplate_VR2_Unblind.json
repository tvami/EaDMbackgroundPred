{
    "NAME": "EaDM",
    "GLOBAL": {
        "FILE": "EaDM_$process.root",
        "HIST": "h$region",
        "HIST_UP": "h$region_$syst_up",
        "HIST_DOWN": "h$region_$syst_down",
        "path": "./histograms_for_2DAlphabet_v23",
        "SIGNAME": ["SIGNAME_PLACEHOLDER"]
    },
    "REGIONS": {
        "pass": {
            "PROCESSES": ["SIGNAME"],
            "BINNING": "default"
        },
        "fail": {
            "PROCESSES": ["SIGNAME"],
            "BINNING": "default"
        }
    },
    "PROCESSES": {
        "data_obs": {
            "SYSTEMATICS":[],
            "COLOR": "black",
            "SCALE": 1,
            "TYPE": "DATA",
            "TITLE": "Run-3 Cosmics VR",
            "ALIAS": "Run3_Cosmics_Data_All_VR2",
            "LOC": "path/FILE:HIST"
        },
        "SIGNAME": {
            "SYSTEMATICS":["lumi","RNN","pT","t0"],
            "COLOR": "red",
            "SCALE": 1.0,
            "TYPE": "SIGNAL",
            "TITLE": "DM signal",
            "LOC": "path/FILE:HIST"
        }
    },
    "SYSTEMATICS": {
        "lumi": {
                "CODE": 0,
                "VAL": 1.05
        },
        "pT": {
            "ALIAS": "pTsyst",
            "UP": "path/FILE:HIST_UP",
            "DOWN": "path/FILE:HIST_DOWN",
            "SIGMA": 1.0
        },
        "t0": {
            "ALIAS": "t0syst",
            "UP": "path/FILE:HIST_UP",
            "DOWN": "path/FILE:HIST_DOWN",
            "SIGMA": 1.0
        },
        "RNN": {
            "ALIAS": "RNNsyst",
            "UP": "path/FILE:HIST_UP",
            "DOWN": "path/FILE:HIST_DOWN",
            "SIGMA": 1.0
        }

    },
    "BINNING": {
        "default": {
            "X": {
                "NAME": "pT",
                "TITLE": "p_{T}",
                "BINS":   [10, 19, 34, 55, 82, 115, 155, 200],
                "SIGSTART": 115,
                "SIGEND": 155,
		"NBINStest": 50,
		"MINtest": 500,
		"MAXtest": 5500
            },
            "Y": {
                "NAME": "N",
                "TITLE": "N",
                "NBINS": 1,
                "MIN": 1,
                "MAX": 200
            }
        }
    },
    "OPTIONS": {
        "blindedFitNA": ["pass"],
        "blindedPlotsNA": ["pass"],
        "plotTemplateComparisonsNA": true,
        "plotEvtsPerUnitVolt" : true
    }
}

